{
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(echo:*)",
      "Bash(pwd:*)",
      "Bash(which:*)",
      "Bash(whoami:*)",
      "Bash(date:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(diff:*)",
      "Bash(cut:*)",
      "Bash(tr:*)",
      "Bash(awk:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(php:*)",
      "Bash(php artisan:*)",
      "Bash(composer:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(vendor/bin/pest:*)",
      "Bash(vendor/bin/phpunit:*)",
      "Bash(php artisan test:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(touch:*)",
      "Bash(chmod:*)",
      "Bash(open:*)",
      "Bash(sed:*)",
      "Bash(make:*)",
      "Bash(brew:*)",
      "Bash(composer show:*)",
      "WebSearch",
      "WebFetch"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "php-lsp@claude-plugins-official": true,
    "laravel-simplifier@laravel": true,
    "ralph-loop@claude-plugins-official": true
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Engineering skills available: tdd-pest, debugging, plan-writing, subagent-dispatch, pressure-test. Check if one applies before starting work.'",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash ~/.claude/config-override-check.sh",
            "timeout": 3000
          }
        ]
      }
    ]
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high"
}
