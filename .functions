# Git

clone() {
  if [[ -z $1 ]]; then
    echo "clone(): repository url not specified"
    echo "usage: clone https://github.com/{USER}/{REPOSITORY}.git"
    return 1
  fi

  local repo_url="$1"
  local repo_name=$(basename "$repo_url" ".${repo_url##*.}")
  git clone "$repo_url"
  cd "$repo_name"
}

commit() {
  git add .
  git commit -m "${1:-wip}"
}

# PHP version switching

php83() {
  brew unlink php php@8.4 php@8.3 2>/dev/null
  brew link php@8.3 --force --overwrite
  echo "Switched to $(php -v | head -1)"
}

php84() {
  brew unlink php php@8.3 php@8.4 2>/dev/null
  brew link php@8.4 --force --overwrite
  echo "Switched to $(php -v | head -1)"
}

php85() {
  brew unlink php@8.3 php@8.4 php 2>/dev/null
  brew link php --force --overwrite
  echo "Switched to $(php -v | head -1)"
}

# Project navigation

__proj_list() {
  local base=~/Code
  {
    find "$base"/{personal,work,learning,playground,oss} -mindepth 1 -maxdepth 1 -type d 2>/dev/null
    find "$base"/{personal,work}/{sites,wordpress,careerfoundry,leedya} -mindepth 1 -maxdepth 1 -type d 2>/dev/null
  } | sort -u | sed "s|$HOME/Code/||" | grep -v -E '^(personal|work)/(sites|wordpress|careerfoundry|leedya)$'
}

proj() {
  local selected
  selected=$(__proj_list | fzf --prompt="Project> " --preview="ls -1 $HOME/Code/{}")
  if [[ -n "$selected" ]]; then
    cd ~/Code/"$selected"
  fi
}

proj-status() {
  setopt local_options null_glob
  local categories
  if [[ -n "$1" ]]; then
    categories=("$1")
  else
    categories=(personal work learning oss)
  fi
  for cat in "${categories[@]}"; do
    for dir in ~/Code/$cat/**/.git(/); do
      local repo="${dir:h}"
      local name="${repo/$HOME\/Code\//}"
      local st=$(git -C "$repo" status --porcelain 2>/dev/null)
      if [[ -n "$st" ]]; then
        echo "\033[1;33m$name\033[0m — dirty"
      else
        echo "\033[1;32m$name\033[0m — clean"
      fi
    done
  done
}

# Playground

scratch() {
  local name="${1:-scratch}"
  local days="${2:-30}"
  local dir=~/Code/playground/"${name}-$(date +%Y%m%d-%H%M%S)"
  mkdir -p "$dir"
  echo "$(date -v+${days}d +%Y-%m-%d)" > "$dir/.expires"
  cd "$dir"
  git init
  echo "# $name" > README.md
  echo "Created: $(date)" >> README.md
  echo "Expires: $(cat .expires)" >> README.md
  echo "Created playground: $dir (expires in ${days} days)"
}

scratch-refresh() {
  local days="${1:-30}"
  local expires_file="$PWD/.expires"
  if [[ ! -f "$expires_file" ]]; then
    echo "Not in a playground (no .expires file found)"
    return 1
  fi
  local old_exp=$(cat "$expires_file")
  echo "$(date -v+${days}d +%Y-%m-%d)" > "$expires_file"
  local new_exp=$(cat "$expires_file")
  echo "Refreshed: $old_exp -> $new_exp (+${days} days)"
}

promote() {
  local target="${1:?Usage: promote <category> (e.g., promote personal)}"
  local name=$(basename "$PWD")
  local dest=~/Code/"$target"/"$name"
  mv "$PWD" "$dest"
  cd "$dest"
  rm -f .expires
  echo "Promoted to $dest"
}

playground-clean() {
  local today=$(date +%Y-%m-%d)
  for dir in ~/Code/playground/*/; do
    local exp=$(cat "$dir/.expires" 2>/dev/null)
    if [[ -n "$exp" && "$today" > "$exp" ]]; then
      echo "Expired: $(basename $dir) (was $exp)"
      rm -rf "$dir"
    fi
  done
  echo "Cleanup complete."
}

# Help

proj-help() {
  echo ""
  echo "  \033[1mProject Navigation & Management\033[0m"
  echo ""
  echo "  \033[1;36mNavigation\033[0m"
  echo "    proj                        Fuzzy find and cd into a project"
  echo "    proj-status [category]      Git status across projects (all or filtered)"
  echo ""
  echo "  \033[1;36mPlayground\033[0m"
  echo "    scratch <name> [days]       Create a playground (default: 30 days)"
  echo "    scratch-refresh [days]      Extend expiration (default: 30 more days)"
  echo "    promote <category>          Move current playground to a category"
  echo "    playground-clean            Delete expired playgrounds"
  echo ""
  echo "  \033[1;36mQuick Jumps\033[0m"
  echo "    cdp                         ~/Code/personal"
  echo "    cdw                         ~/Code/work"
  echo "    cdl                         ~/Code/learning"
  echo "    cdx                         ~/Code/playground"
  echo "    cda                         ~/Code/archive"
  echo "    cdo                         ~/Code/oss"
  echo ""
  echo "  \033[1;36mExamples\033[0m"
  echo "    proj                        Pick any project with fuzzy search"
  echo "    scratch redis-test          New playground, expires in 30 days"
  echo "    scratch api-spike 60        New playground, expires in 60 days"
  echo "    scratch-refresh              Extend by 30 days from today"
  echo "    scratch-refresh 60           Extend by 60 days from today"
  echo "    promote personal            Graduate playground to personal/"
  echo "    playground-clean            Remove all expired playgrounds"
  echo ""
}
